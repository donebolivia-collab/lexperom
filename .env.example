# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secreta. Solo servidor. NUNCA anteponer NEXT_PUBLIC_ ni exponer al navegador.
SUPABASE_SERVICE_ROLE_KEY=

# IA (opcional). Sin esta variable, el sistema usa un análisis por reglas
# como respaldo y sigue funcionando de extremo a extremo.
# Obtener clave gratuita en https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# URL pública del sitio en producción (usada en metadata, sitemap, OG tags).
NEXT_PUBLIC_SITE_URL=https://dominio-pendiente.example.com

# Analytics (opcional, se activan solo si están presentes)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
